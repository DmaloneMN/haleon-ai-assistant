# Example environment variables – copy to .env and fill in your values
# Do NOT commit .env to source control

# Server
HOST=127.0.0.1
PORT=8000
RELOAD=false

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=haleon-docs

# Azure Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=

# Azure Key Vault
AZURE_KEYVAULT_URL=https://<your-vault>.vault.azure.net/

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_URL=https://<your-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=documents

# Redis
REDIS_URL=redis://localhost:6379
