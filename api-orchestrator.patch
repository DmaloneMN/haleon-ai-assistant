+import time
+from collections import defaultdict
+
+_COUNTS = defaultdict(list)
+RATE_LIMIT = 60  # seconds window
+MAX_REQUESTS = 100
+
+def allow_request(key: str) -> bool:
+    """Very small in-memory rate limiter used only for local testing/scaffold."""
+    now = time.time()
+    window = [t for t in _COUNTS[key] if now - t < RATE_LIMIT]
+    _COUNTS[key] = window
+    if len(window) < MAX_REQUESTS:
+        _COUNTS[key].append(now)
+        return True
+    return False
+
