+from typing import List
+
+
+def embed(text: str, dim: int = 8) -> List[float]:
+    """
+    Deterministic pseudo-embedding using Python's hash.
+    Produces a small list of floats in range [0,1].
+    """
+    if text is None:
+        text = ""
+    h = abs(hash(text))
+    vec: List[float] = []
+    for i in range(dim):
+        # shift and mask to produce reproducible values
+        val = ((h >> (i * 8)) & 0xFF) / 255.0
+        vec.append(float(val))
+    return vec
+
