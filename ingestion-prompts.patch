+from typing import Dict, List
+
+from haleon_assistant.ingestion.chunker import chunk_text
+from haleon_assistant.ingestion.embedder import embed
+from haleon_assistant.ingestion.indexer import index_documents
+
+
+def run_pipeline(doc_text: str) -> Dict:
+    """
+    Run the simple pipeline: chunk -> embed -> index.
+    Returns index_documents() result.
+    """
+    chunks: List[str] = chunk_text(doc_text)
+    docs = []
+    for i, c in enumerate(chunks):
+        docs.append({"id": f"chunk-{i}", "text": c, "vector": embed(c)})
+    return index_documents(docs)
+
