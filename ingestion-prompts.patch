+from typing import List, Dict
+
+# Simple in-memory index store used for scaffold/testing.
+_IN_MEMORY_INDEX: List[Dict] = []
+
+
+def index_documents(docs: List[Dict]) -> Dict:
+    """
+    Indexes documents into a global in-memory list and returns a summary.
+    Each doc should be a dict with at least 'text' and 'vector' keys.
+    """
+    count_before = len(_IN_MEMORY_INDEX)
+    for d in docs:
+        _IN_MEMORY_INDEX.append(d)
+    return {"indexed": len(docs), "total": len(_IN_MEMORY_INDEX), "before": count_before}
+
+
+def clear_index() -> None:
+    """Clear the in-memory index (useful for tests)."""
+    _IN_MEMORY_INDEX.clear()
+
