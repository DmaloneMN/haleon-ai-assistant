+    chunks = chunk_text(text, chunk_size=200)
+    assert isinstance(chunks, list)
+    assert len(chunks) >= 1
+    # All chunks when joined produce the original words count (ignoring trailing spaces)
+    joined = " ".join(chunks).strip()
+    assert joined.count("word") == 1200
