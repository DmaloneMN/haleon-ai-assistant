+from typing import List
+
+
+def chunk_text(text: str, chunk_size: int = 500) -> List[str]:
+    """
+    Very small deterministic chunker: split text into contiguous chunks of
+    approximately chunk_size characters on whitespace boundaries.
+    """
+    if not text:
+        return []
+    words = text.split()
+    chunks: List[str] = []
+    current = []
+    current_len = 0
+    for w in words:
+        if current_len + len(w) + (1 if current else 0) > chunk_size:
+            chunks.append(" ".join(current))
+            current = [w]
+            current_len = len(w)
+        else:
+            current.append(w)
+            current_len += len(w) + (1 if current_len else 0)
+    if current:
+        chunks.append(" ".join(current))
+    return chunks
+
