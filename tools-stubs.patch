+def lookup_dosage(product_id: str) -> dict:
+    """Return a minimal deterministic dosage record for a product id."""
+    if not product_id:
+        return {"product_id": product_id, "dosage": "unknown"}
+    # Simple mapping for scaffold/testing
+    return {"product_id": product_id, "dosage": "Follow label instructions (1 tablet)"}
+
